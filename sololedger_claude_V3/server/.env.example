# Server
PORT=3001
JWT_SECRET=change-me-to-a-long-random-string
CORS_ORIGIN=http://localhost:5173,https://ramakanthgade.github.io

# Persistent user store (required on Railway — attach a Volume at this path)
# DATA_DIR=/data

# Admin account (created on first boot if missing)
ADMIN_EMAIL=you@example.com
ADMIN_PASSWORD=change-me

# Subscriber-facing feature defaults (admin can override via /api/admin/config)
PRICE_API_ENABLED=true
RPC_LOOKUP_ENABLED=true
AI_ADVISOR_ENABLED=true

# Your API keys — never exposed to subscribers
ALCHEMY_API_KEY=
COINGECKO_API_KEY=
HELIUS_API_KEY=
MORALIS_API_KEY=
BIRDEYE_API_KEY=
NOVES_API_KEY=
OPENROUTER_API_KEY=
ETHERSCAN_API_KEY=

# Stripe (optional — omit to use manual / dev subscriptions)
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRICE_STARTER=
STRIPE_PRICE_STANDARD=
STRIPE_PRICE_PRO=
